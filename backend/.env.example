# ====================================
# CAREMATE BACKEND CONFIGURATION TEMPLATE
# ====================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets!
# ====================================


# ====================================
# SERVER CONFIGURATION
# ====================================

# Environment (development, production, test)
NODE_ENV=development

# Server port (default: 5000)
PORT=5000

# Frontend URL(s) for CORS and email links.
# Use a comma-separated list when you need local + deployed URLs.
CLIENT_URL=http://localhost:5173

# Optional: allow Vercel preview deployments (*.vercel.app) during testing.
ALLOW_VERCEL_PREVIEWS=false


# ====================================
# DATABASE CONFIGURATION
# ====================================

# MongoDB Connection URI
# Local: mongodb://localhost:27017/caremate
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/caremate
MONGODB_URI=mongodb://localhost:27017/caremate


# ====================================
# JWT AUTHENTICATION
# ====================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Use: openssl rand -base64 32 to generate a strong key
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# JWT Token Expiration (e.g., 7d, 30d, 1h)
JWT_EXPIRE=30d

# Google OAuth client ID used to verify Google sign-in tokens
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google reCAPTCHA secret key used by the backend to verify login/register challenges
RECAPTCHA_SECRET=your-recaptcha-secret-key

# Required only when creating an admin account through /api/v1/auth/register
ADMIN_SETUP_KEY=9993625635


# ====================================
# EMAIL CONFIGURATION
# ====================================

# For Gmail - use App Password (not your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=carematesupport@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=carematesupport@gmail.com

# For testing - use Ethereal (https://ethereal.email)
# EMAIL_HOST=smtp.ethereal.email
# EMAIL_PORT=587
# EMAIL_USER=ethereal-username
# EMAIL_PASS=ethereal-password


# ====================================
# AI MICROSERVICE
# ====================================

# Python FastAPI microservice URL
AI_SERVICE_URL=http://localhost:8000/api
AI_SERVICE_API_KEY=your-ai-service-api-key
AI_SERVICE_TIMEOUT=30000


# ====================================
# RATE LIMITING
# ====================================

# General API rate limit (15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth rate limit (stricter - 5 attempts per 15 minutes)
AUTH_RATE_LIMIT_MAX_REQUESTS=5


# ====================================
# FILE UPLOADS
# ====================================

# Max file size in bytes (5MB default)
MAX_FILE_SIZE=5242880

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf


# ====================================
# REMINDER SCHEDULER
# ====================================

# Enable/disable the reminder scheduler
SCHEDULER_ENABLED=true

# Check medication reminders every X minutes
MEDICATION_CHECK_INTERVAL=1

# Check appointment reminders every X hours
APPOINTMENT_CHECK_INTERVAL=1

# Time to generate daily reminders (24h format)
DAILY_REMINDER_TIME=00:00


# ====================================
# FEATURE FLAGS
# ====================================

# Enable/disable AI features
ENABLE_AI_FEATURES=true

# Enable/disable email notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable/disable video consultations
ENABLE_VIDEO_CONSULTATIONS=true


# ====================================
# SECURITY (Optional)
# ====================================

# Cookie signing secret
COOKIE_SECRET=your-cookie-secret

# Bcrypt salt rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=10


# ====================================
# PAGINATION DEFAULTS
# ====================================

DEFAULT_PAGE_LIMIT=10
MAX_PAGE_LIMIT=100


# ====================================
# LOGGING
# ====================================

LOG_LEVEL=debug
LOG_PATH=./logs


# ====================================
# TEST CONFIGURATION
# ====================================

# Separate database for testing
TEST_MONGODB_URI=mongodb://localhost:27017/caremate_test
