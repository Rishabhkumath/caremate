# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60

# Logging
LOG_LEVEL=info

# API Version
API_VERSION=v1
